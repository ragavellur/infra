#!/bin/bash
# DEPRECATED: This script has been replaced by bharatradar-install
# This script redirects to the new unified installer.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo ""
echo "[INFO] bharatradar-setup is deprecated."
echo "[INFO] Use 'bharatradar-install' instead."
echo ""

# Check if new installer exists
if [ -f "${SCRIPT_DIR}/bharatradar-install" ]; then
    echo "[INFO] Redirecting to bharatradar-install..."
    echo ""
    exec "${SCRIPT_DIR}/bharatradar-install" "$@"
else
    echo "[ERROR] bharatradar-install not found at ${SCRIPT_DIR}/bharatradar-install"
    echo "[ERROR] Please update your scripts from the repository."
    exit 1
fi

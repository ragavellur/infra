#!/bin/bash
# BharatRadar Infrastructure Installer v2.0.5
#
# Main entry point for all installation workflows.
# Supports interactive mode and non-interactive (role-based) mode.
#
# Usage:
#   sudo ./bharatradar-install                    # Interactive wizard
#   sudo ./bharatradar-install frp-server         # FRP server setup
#   sudo ./bharatradar-install hub                # Hub setup
#   sudo ./bharatradar-install aggregator         # Aggregator node setup
#   sudo ./bharatradar-install feeder             # Feeder Pi setup
#   sudo ./bharatradar-install status             # Show health dashboard
#   sudo ./bharatradar-install uninstall [role]   # Remove components
#   sudo ./bharatradar-install update             # Update scripts and redeploy
#   sudo ./bharatradar-install backup             # Backup configs
#
# Online install:
#   curl -Ls https://raw.githubusercontent.com/ragavellur/infra/main/scripts/bharatradar-install | sudo bash

set -eo pipefail

VERSION="3.5.3"

# Determine script directory
# When piped (curl | bash), BASH_SOURCE is empty — we do a shallow clone instead
SELF_INSTALL=false
if [ -z "${BASH_SOURCE[0]+x}" ] || [ -z "${BASH_SOURCE[0]}" ]; then
    SELF_INSTALL=true
fi

if [ "$SELF_INSTALL" = true ]; then
    log_info() { echo -e "\033[0;34m[INFO]\033[0m $1"; }
    log_step() { echo -e "\n\033[0;36m>>> $1\033[0m"; }

    log_step "Downloading installer..."
    TMPDIR=$(mktemp -d /tmp/bharatradar-install.XXXXXX)
    git clone --depth 1 --sparse -b main \
        https://github.com/ragavellur/infra.git "${TMPDIR}/infra" 2>/dev/null || {
        # Fallback: full shallow clone if sparse not supported
        git clone --depth 1 -b main \
            https://github.com/ragavellur/infra.git "${TMPDIR}/infra" 2>/dev/null || {
            log_info "Git clone failed, trying direct download..."
            for f in scripts/bharatradar-install scripts/helpers/functions.sh scripts/helpers/templating.sh scripts/helpers/verify.sh scripts/helpers/uninstall.sh scripts/helpers/ssh-helpers.sh scripts/roles/frp-server.sh scripts/roles/hub.sh scripts/roles/ha-server.sh scripts/roles/worker.sh scripts/roles/shared-services.sh scripts/roles/db-standby.sh scripts/roles/feeder.sh scripts/roles/keepalived.sh scripts/roles/aggregator.sh; do
                mkdir -p "${TMPDIR}/$(dirname "$f")"
                curl -sL "https://raw.githubusercontent.com/ragavellur/infra/main/${f}" -o "${TMPDIR}/${f}"
            done
            # Download manifests for hub role
            curl -sL "https://github.com/ragavellur/infra/archive/refs/heads/main.tar.gz" | tar xz -C "${TMPDIR}" --strip-components=1 "infra-main/manifests" 2>/dev/null || true
            chmod +x "${TMPDIR}/scripts/bharatradar-install"
            exec bash "${TMPDIR}/scripts/bharatradar-install" "$@"
        }
    }

    # If sparse clone succeeded, set sparse-checkout
    if [ -d "${TMPDIR}/infra/.git" ]; then
        cd "${TMPDIR}/infra"
        git sparse-checkout init --cone 2>/dev/null || true
        git sparse-checkout set scripts manifests 2>/dev/null || true
        git checkout 2>/dev/null || true
        cd - >/dev/null
    fi

    SCRIPT_DIR="${TMPDIR}/infra/scripts"
    export SCRIPT_DIR INSTALL_TMPDIR="$TMPDIR"
    chmod +x "${SCRIPT_DIR}/bharatradar-install"
    exec bash "${SCRIPT_DIR}/bharatradar-install" "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Clean up temp directory from self-install when done
if [ -n "${INSTALL_TMPDIR:-}" ] && [ -d "${INSTALL_TMPDIR}" ]; then
    trap 'rm -rf "${INSTALL_TMPDIR}"' EXIT
fi

# Source helper functions
source "${SCRIPT_DIR}/helpers/functions.sh"

# Global configuration (loaded from config.env if present)
ROLE="${ROLE:-}"
SUB_ROLE="${SUB_ROLE:-}"
BASE_DOMAIN="${BASE_DOMAIN:-}"
READSB_LAT="${READSB_LAT:-18.480718}"
READSB_LON="${READSB_LON:-73.898235}"
TIMEZONE="${TIMEZONE:-UTC}"
HUB_IP="${HUB_IP:-}"
K3S_TOKEN="${K3S_TOKEN:-}"
FRP_SERVER="${FRP_SERVER:-}"
FRP_TOKEN="${FRP_TOKEN:-}"
FEEDER_DOMAIN="${FEEDER_DOMAIN:-feed.bharat-radar.vellur.in}"
FRP_VERSION="0.68.1"

# Load existing configuration
load_config() {
    if [ -f /etc/bharatradar/config.env ]; then
        source /etc/bharatradar/config.env
        log_info "Loaded existing configuration from /etc/bharatradar/config.env"
    fi
}

# Print the welcome banner
print_banner() {
    echo ""
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}        BharatRadar Infrastructure v${VERSION}${NC}"
    echo -e "${CYAN}        ADS-B/MLAT Aggregator Platform${NC}"
    echo -e "${CYAN}================================================================${NC}"
    echo ""
}

# Check system prerequisites
check_prerequisites() {
    log_step "Checking Prerequisites"

    # Check root
    if [ "$(id -u)" -ne 0 ]; then
        log_error "This script must be run as root. Use 'sudo'."
        exit 1
    fi
    log_success "Root access: OK"

    # Check OS
    local os
    os=$(detect_os)
    case "$os" in
        debian|ubuntu|raspbian)
            log_success "OS: $(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2 || echo 'Linux')"
            ;;
        fedora|centos|rhel)
            log_success "OS: $(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2 || echo 'Linux')"
            ;;
        *)
            log_error "Unsupported OS: ${os}"
            log_info "Supported: Debian, Ubuntu, Raspberry Pi OS, Fedora, CentOS, RHEL"
            exit 1
            ;;
    esac

    # Check architecture
    local arch
    arch=$(detect_arch)
    case "$arch" in
        amd64|arm64|arm)
            log_success "Architecture: ${arch}"
            ;;
        *)
            log_error "Unsupported architecture: ${arch}"
            log_info "Supported: amd64 (x86_64), arm64 (aarch64), arm (armv7l)"
            exit 1
            ;;
    esac

    # Check network
    if ping -c1 -W2 8.8.8.8 &>/dev/null; then
        log_success "Network connectivity: OK"
    else
        log_warn "Network connectivity test failed (may still work)"
    fi

    # Check available disk space
    local available_gb
    available_gb=$(df / --output=avail 2>/dev/null | tail -1 | awk '{printf "%.0f", $1/1048576}')
    if [ "${available_gb:-0}" -lt 5 ]; then
        log_warn "Low disk space: ${available_gb}GB available (5GB+ recommended)"
    else
        log_success "Disk space: ${available_gb}GB available"
    fi

    echo ""
}

# Sub-role prompt: K3s Cluster
select_k3s_subrole() {
    echo ""
    echo -e "${CYAN}K3s Cluster Setup${NC}"
    echo ""
    echo "  1) New Cluster (Primary Hub)   - First server, creates cluster"
    echo "  2) Join as HA Server           - Second server, shares control plane"
    echo "  3) Join as Worker              - Agent node, runs pods only"
    echo ""

    local choice
    while true; do
        read -rp "Select [1-3]: " choice < /dev/tty
        case "$choice" in
            1) ROLE="hub"; SUB_ROLE="primary"; break ;;
            2) ROLE="ha-server"; SUB_ROLE="secondary"; break ;;
            3) ROLE="worker"; SUB_ROLE="agent"; break ;;
            *) echo "Invalid selection. Please enter 1, 2, or 3." ;;
        esac
    done
    echo ""
}

# Sub-role prompt: Shared Services
select_shared_subrole() {
    echo ""
    echo -e "${CYAN}Shared Services Setup${NC}"
    echo ""
    echo "  1) Primary DB Setup     - Fresh PostgreSQL/Redis/InfluxDB install"
    echo "  2) Join as DB Standby   - Streaming replica for failover"
    echo ""

    local choice
    while true; do
        read -rp "Select [1-2]: " choice < /dev/tty
        case "$choice" in
            1) ROLE="shared-services"; SUB_ROLE="primary"; break ;;
            2) ROLE="db-standby"; SUB_ROLE="replica"; break ;;
            *) echo "Invalid selection. Please enter 1 or 2." ;;
        esac
    done
    echo ""
}

# Sub-role prompt: Manage
select_manage_action() {
    echo ""
    echo -e "${CYAN}Manage${NC}"
    echo ""
    echo "  1) Status             - Show health dashboard"
    echo "  2) Remove Node        - Remove a node from cluster"
    echo "  3) Backup             - Backup configuration files"
    echo "  4) Update             - Update scripts and redeploy"
    echo ""

    local choice
    while true; do
        read -rp "Select [1-4]: " choice < /dev/tty
        case "$choice" in
            1) ROLE="status"; break ;;
            2) ROLE="remove-node"; break ;;
            3) ROLE="backup"; break ;;
            4) ROLE="update"; break ;;
            *) echo "Invalid selection. Please enter 1, 2, 3, or 4." ;;
        esac
    done
    echo ""
}

# Interactive role selection
select_role() {
    echo ""
    echo -e "${CYAN}What would you like to set up?${NC}"
    echo ""
    echo "  1) Shared Services  - PostgreSQL, Redis, InfluxDB"
    echo "                        (Data layer for K3s cluster)"
    echo ""
    echo "  2) K3s Cluster      - Kubernetes server or worker"
    echo "                        (Map, API, MLAT, web services)"
    echo ""
    echo "  3) Feeder Pi        - RTL-SDR receiver"
    echo "                        (Feeds ADS-B data to cluster)"
    echo ""
    echo "  4) FRP Server       - Cloud/VPS with public IP"
    echo "                        (Tunnel for NAT'd clusters)"
    echo ""
    echo "  5) Manage           - Status, Remove Node, Backup, Update"
    echo ""

    local choice
    while true; do
        read -rp "Select [1-5]: " choice < /dev/tty
        case "$choice" in
            1) select_shared_subrole; return ;;
            2) select_k3s_subrole; return ;;
            3) ROLE="feeder"; return ;;
            4) ROLE="frp-server"; return ;;
            5) select_manage_action; return ;;
            *) echo "Invalid selection. Please enter 1, 2, 3, 4, or 5." ;;
        esac
    done
    echo ""
}

# Run the selected role
run_role() {
    case "$ROLE" in
        status)
            cmd_status
            return
            ;;
        remove-node)
            source "${SCRIPT_DIR}/helpers/ssh-helpers.sh"
            remove_node_interactive
            return
            ;;
        backup)
            cmd_backup
            return
            ;;
        update)
            cmd_update
            return
            ;;
    esac

    local role_file="${SCRIPT_DIR}/roles/${ROLE}.sh"

    if [ ! -f "$role_file" ]; then
        log_error "Unknown role: ${ROLE}"
        log_info "Available roles: frp-server, hub, ha-server, worker, shared-services, db-standby, feeder"
        exit 1
    fi

    log_info "Starting ${ROLE} setup..."
    echo ""

    # Source and run the role
    source "$role_file"
    "role_${ROLE//-/_}_run"
}

# Status command
cmd_status() {
    load_config

    source "${SCRIPT_DIR}/helpers/verify.sh"

    local role="${ROLE:-unknown}"
    local domain="${BASE_DOMAIN:-unknown}"

    verify_status "$role" "$domain"
}

# Uninstall command
cmd_uninstall() {
    source "${SCRIPT_DIR}/helpers/uninstall.sh"

    uninstall_all "${1:-}"
}

# Update command: pull latest scripts and redeploy
cmd_update() {
    log_step "Updating BharatRadar"

    load_config

    if [ -z "${ROLE:-}" ]; then
        log_error "No role found in configuration. Run setup first."
        exit 1
    fi

    log_info "Current role: ${ROLE}"
    log_info "Domain: ${BASE_DOMAIN:-unknown}"
    echo ""

    # For hub/ha-server nodes, redeploy manifests
    if [ "${ROLE}" = "hub" ] || [ "${ROLE}" = "ha-server" ]; then
        log_step "Redeploying manifests..."

        if command -v kustomize &>/dev/null; then
            kustomize build "${SCRIPT_DIR}/../manifests/default" 2>/dev/null | kubectl apply -f - -n bharatradar || {
                log_warn "kustomize build failed"
            }
        fi

        log_success "Manifests redeployed"
    fi

    # Check for script updates
    if command -v git &>/dev/null && [ -d "${SCRIPT_DIR}/../.git" ]; then
        log_info "Checking for script updates..."
        cd "${SCRIPT_DIR}/.."
        if git fetch origin &>/dev/null; then
            local behind
            behind=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "0")
            if [ "$behind" -gt 0 ]; then
                log_info "${behind} update(s) available"
                if prompt_confirm "Pull and apply updates?"; then
                    git pull origin main
                    log_success "Scripts updated"
                fi
            else
                log_success "Scripts are up to date"
            fi
        fi
        cd - >/dev/null
    fi

    echo ""
    log_success "Update complete"
}

# Backup command
cmd_backup() {
    log_step "Backing up Configuration"

    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local backup_file="/tmp/bharatradar-backup-${timestamp}.tar.gz"

    local backup_dirs=()

    if [ -d /etc/bharatradar ]; then
        backup_dirs+=("/etc/bharatradar")
    fi

    if [ -f /etc/frpc.toml ]; then
        backup_dirs+=("/etc/frpc.toml")
    fi

    if [ -f /etc/frps.toml ]; then
        backup_dirs+=("/etc/frps.toml")
    fi

    if [ -d /etc/systemd/system ] && ls /etc/systemd/system/bharat-*.service /etc/systemd/system/frp*.service 2>/dev/null | head -1 &>/dev/null; then
        backup_dirs+=("/etc/systemd/system/bharat-feeder.service" "/etc/systemd/system/bharat-mlat.service" "/etc/systemd/system/frps.service" "/etc/systemd/system/frpc.service")
    fi

    if [ -f /etc/bharat-radar-id ]; then
        backup_dirs+=("/etc/bharat-radar-id")
    fi

    if [ ${#backup_dirs[@]} -eq 0 ]; then
        log_warn "No configuration files found to backup"
        return 0
    fi

    tar czf "$backup_file" "${backup_dirs[@]}" 2>/dev/null
    chmod 600 "$backup_file"

    log_success "Backup created: ${backup_file}"
    log_info "Restore with: sudo tar xzf ${backup_file} -C /"
}

# Show usage
usage() {
    cat <<EOF
BharatRadar Infrastructure Installer v${VERSION}

Usage:
  sudo $0 [COMMAND]

Commands:
  (no args)       Run interactive setup wizard
  shared-services Set up shared data services (PostgreSQL, Redis, InfluxDB)
  db-standby      Set up PostgreSQL streaming replica
  hub             Set up Primary Hub (first K3s server, new cluster)
  ha-server       Join existing cluster as second K3s server (HA)
  worker          Join existing cluster as K3s agent
  feeder          Set up RTL-SDR receiver
  frp-server      Set up FRP server on cloud/VPS
  status          Show health dashboard
  remove-node     Remove a node from cluster (interactive)
  update          Update scripts and redeploy
  backup          Backup configuration files
  uninstall       Remove BharatRadar components
  help            Show this help message

Online Install:
  curl -Ls https://raw.githubusercontent.com/ragavellur/infra/main/scripts/bharatradar-install | sudo bash
  curl -Ls https://raw.githubusercontent.com/ragavellur/infra/main/scripts/bharatradar-install | sudo bash -s -- hub
  curl -Ls https://raw.githubusercontent.com/ragavellur/infra/main/scripts/bharatradar-install | sudo bash -s -- worker
  curl -Ls https://raw.githubusercontent.com/ragavellur/infra/main/scripts/bharatradar-install | sudo bash -s -- feeder

Examples:
  # Interactive setup wizard
  sudo $0

  # Non-interactive: Primary Hub (new cluster)
  sudo $0 hub

  # Non-interactive: Join as HA server
  sudo $0 ha-server

  # Non-interactive: Join as worker node
  sudo $0 worker

  # Shared services (prompts for primary vs standby)
  sudo $0 shared-services

  # Check cluster status
  sudo $0 status
EOF
}

# Main entry point
main() {
    load_config

    local command="${1:-}"

    case "$command" in
        frp-server|hub|ha-server|worker|shared-services|db-standby|feeder)
            print_banner
            check_prerequisites
            ROLE="$command"
            # shared-services always prompts for sub-mode
            if [ "$ROLE" = "shared-services" ] && [ -z "${SUB_ROLE:-}" ]; then
                select_shared_subrole
            fi
            run_role
            ;;
        status|update|backup)
            cmd_"$command"
            ;;
        uninstall)
            cmd_uninstall "${2:-}"
            ;;
        remove-node)
            source "${SCRIPT_DIR}/helpers/ssh-helpers.sh"
            remove_node_interactive
            ;;
        help|--help|-h)
            usage
            ;;
        "")
            print_banner
            check_prerequisites
            select_role
            run_role
            ;;
        *)
            log_error "Unknown command: ${command}"
            usage
            exit 1
            ;;
    esac
}

main "$@"
